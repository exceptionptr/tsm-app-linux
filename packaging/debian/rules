#!/usr/bin/make -f
%:
	dh $@ --with python3

override_dh_auto_build:
	python3 -m build --wheel --no-isolation

override_dh_auto_install:
	python3 -m installer --destdir=debian/tsm-app dist/*.whl
	install -Dm644 packaging/tsm-app.desktop \
		debian/tsm-app/usr/share/applications/tsm-app.desktop
	install -Dm644 LICENSE \
		debian/tsm-app/usr/share/doc/tsm-app/copyright

override_dh_auto_test:
